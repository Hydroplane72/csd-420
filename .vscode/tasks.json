{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Assignment (JavaFX)",
      "type": "shell",
      "command": "javac",
      "args": [
        "--module-path",
        "${env:JAVAFX_HOME}\\lib",
        "--add-modules",
        "javafx.controls,javafx.fxml",
        "-d",
        "${workspaceFolder}\\out",
        "${workspaceFolder}\\module-1\\Assignment\\src\\main\\java\\com\\assignment\\App.java",
        "${workspaceFolder}\\module-1\\Assignment\\src\\main\\java\\com\\assignment\\PrimaryController.java"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": "$javac",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}